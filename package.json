{
  "name": "gearbase",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @gearbase/canvas-web dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "gen:clients": "pnpm --filter @gearbase/clients gen",
    "smoke": "tsx scripts/smoke.ts",
    "deploy:rooms": "tsx scripts/deploy.ts",
    "create:room": "tsx scripts/create-room.ts",
    "read:room": "tsx scripts/read-room.ts"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "@gearbase/sdk": "workspace:*"
  }
}
