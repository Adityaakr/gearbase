
!@sails: 1.0.1

service Room@0xf7b06275678f99bd {
    events {
        Closed,
        Configured(u64),
        Joined([u8; 32]),
        Left([u8; 32]),
        PixelPlaced {
            x: u16,
            y: u16,
            color: u16,
            who: [u8; 32],
        },
        Updated(u64),
    }
    functions {
        CloseRoom() -> u64 throws RoomError;
        Configure(config_blob: [u8]) -> u64 throws RoomError;
        @query
        Info() -> (String, u16, ActorId, u64, [u8]);
        Join(name: String, kind: u16) -> u64 throws RoomError;
        Leave() -> u64 throws RoomError;
        @query
        Participants() -> [(ActorId, String, u16, u64)];
        PlacePixel(x: u16, y: u16, color: u16) -> u64 throws RoomError;
        @query
        Region(x: u16, y: u16, w: u16, h: u16) -> [u8] throws RoomError;
        @query
        Seq() -> u64;
        @query
        Since(from_seq: u64) -> (u64, [(u64, [u8])], bool);
        @query
        Snapshot() -> [u8];
    }
    types {
        enum RoomError {
            Closed,
            NotOwner,
            AlreadyJoined,
            NotJoined,
            NotAllowed,
            ParticipantsFull,
            NameTooLong {
                max_bytes: u16,
            },
            PayloadTooLarge {
                actual_bytes: u32,
                max_bytes: u16,
            },
            RateLimited {
                retry_after_secs: u32,
            },
            InvalidConfig,
            InvalidKind,
            InvalidBounds,
            InvalidColor,
            CooldownActive {
                retry_after_secs: u32,
            },
        }
    }
}

program RoomCanvasClient {
    constructors {
        Create(width: u16, height: u16, palette_size: u16, cooldown_secs: u16);
    }
    services {
        Room@0xf7b06275678f99bd,
    }
}
